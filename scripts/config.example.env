# Example Configuration for Stream Scholar Deployment
# Copy this file to config.env and modify as needed

# Required: Stellar address for contract deployment and admin operations
SOROBAN_ADMIN_ADDRESS=GD5DQ6KZQZJZHQ6Y5X2H5FQD2Z5Z5Z5Z5Z5Z5Z5Z5Z5Z5Z5Z5Z5Z5Z5Z5Z5Z5

# Contract initialization parameters (optional - defaults will be used if not set)
BASE_RATE=100
DISCOUNT_THRESHOLD=3600
DISCOUNT_PERCENTAGE=10
MIN_DEPOSIT=50
HEARTBEAT_INTERVAL=300

# Network configuration (usually don't need to change)
NETWORK=testnet
RPC_URL=https://soroban-testnet.stellar.org:443
NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Existing contract (if working with already deployed contract)
EXISTING_CONTRACT_ID=CB7OZPTIUENDWJWNHRGDPZLIEIS6TXMFRYT4WCGHIZVYLCTXEONC6VHY

# Example teacher addresses (replace with actual addresses)
TEACHER_ADDRESSES=(
    "GD6JQ6KZQZJZHQ6Y5X2H5FQD2Z5Z5Z5Z5Z5Z5Z5Z5Z5Z5Z5Z5Z5Z5Z5Z5Z5Z5"
    "GD7RQ6KZQZJZHQ6Y5X2H5FQD2Z5Z5Z5Z5Z5Z5Z5Z5Z5Z5Z5Z5Z5Z5Z5Z5Z5Z5"
    "GD8SQ6KZQZJZHQ6Y5X2H5FQD2Z5Z5Z5Z5Z5Z5Z5Z5Z5Z5Z5Z5Z5Z5Z5Z5Z5Z5"
)
